<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee
         http://xmlns.jcp.org/xml/ns/javaee/web-app_3_1.xsd"
         version="3.1">

    <!-- ============================================================ -->
    <!--  AulaVirtual — Sistema de Gestión Estudiantil                -->
    <!--  GA7-220501096-AA2-EV02                                      -->
    <!-- ============================================================ -->

    <display-name>AulaVirtual</display-name>
    <description>Sistema de Gestión Estudiantil AulaVirtual</description>

    <welcome-file-list>
        <welcome-file>index.jsp</welcome-file>
    </welcome-file-list>

    <!-- Login -->
    <servlet>
        <servlet-name>LoginServlet</servlet-name>
        <servlet-class>controlador.LoginServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>LoginServlet</servlet-name>
        <url-pattern>/login</url-pattern>
    </servlet-mapping>

    <!-- Registro -->
    <servlet>
        <servlet-name>RegistroServlet</servlet-name>
        <servlet-class>controlador.RegistroServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>RegistroServlet</servlet-name>
        <url-pattern>/registro</url-pattern>
    </servlet-mapping>

    <!-- Recuperar contraseña -->
    <servlet>
        <servlet-name>RecuperarServlet</servlet-name>
        <servlet-class>controlador.RecuperarServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>RecuperarServlet</servlet-name>
        <url-pattern>/recuperar</url-pattern>
    </servlet-mapping>

    <!-- Estudiantes -->
    <servlet>
        <servlet-name>EstudianteServlet</servlet-name>
        <servlet-class>controlador.EstudianteServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>EstudianteServlet</servlet-name>
        <url-pattern>/estudiantes</url-pattern>
    </servlet-mapping>

    <!-- Notas -->
    <servlet>
        <servlet-name>NotasServlet</servlet-name>
        <servlet-class>controlador.NotasServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>NotasServlet</servlet-name>
        <url-pattern>/notas</url-pattern>
    </servlet-mapping>

    <!-- Dashboard -->
    <servlet>
        <servlet-name>DashboardServlet</servlet-name>
        <servlet-class>controlador.DashboardServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>DashboardServlet</servlet-name>
        <url-pattern>/dashboard-admin</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>DashboardServlet</servlet-name>
        <url-pattern>/dashboard-docente</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>DashboardServlet</servlet-name>
        <url-pattern>/dashboard-estudiante</url-pattern>
    </servlet-mapping>

    <!-- Logout -->
    <servlet>
        <servlet-name>LogoutServlet</servlet-name>
        <servlet-class>controlador.LogoutServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>LogoutServlet</servlet-name>
        <url-pattern>/logout</url-pattern>
    </servlet-mapping>

    <!-- Usuarios Admin -->
    <servlet>
        <servlet-name>UsuarioServlet</servlet-name>
        <servlet-class>controlador.UsuarioServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>UsuarioServlet</servlet-name>
        <url-pattern>/usuarios</url-pattern>
    </servlet-mapping>

    <!-- Sesión -->
    <session-config>
        <session-timeout>30</session-timeout>
    </session-config>

    <!-- Errores -->
    <error-page>
        <error-code>404</error-code>
        <location>/index.jsp</location>
    </error-page>
    <error-page>
        <error-code>500</error-code>
        <location>/index.jsp</location>
    </error-page>

</web-app>